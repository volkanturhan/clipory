<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand accent (kept the same across themes). -->
    <SolidColorBrush x:Key="Accent" Color="#4F46E5" />

    <!-- Light surfaces and text. -->
    <SolidColorBrush x:Key="Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Subtle" Color="#F3F4F6" />
    <SolidColorBrush x:Key="Border" Color="#E5E7EB" />
    <SolidColorBrush x:Key="TextPrimary" Color="#111827" />
    <SolidColorBrush x:Key="TextMuted" Color="#6B7280" />

</ResourceDictionary>
