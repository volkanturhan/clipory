<Window x:Class="ClipStack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipStack"
        mc:Ignorable="d"
        Title="ClipStack"
        Width="380" Height="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Deactivated="OnDeactivated">

    <!-- Thin border so the borderless popup still reads as a distinct surface. -->
    <Border BorderBrush="#FF3C3C3C" BorderThickness="1" Background="White">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox" Grid.Row="0"
                     Margin="0,0,0,8" Padding="4"
                     KeyDown="OnSearchKeyDown"
                     TextChanged="OnSearchTextChanged" />

            <ListBox x:Name="HistoryList" Grid.Row="1"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="OnListDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Preview}"
                                   TextTrimming="CharacterEllipsis"
                                   Padding="2" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Margin="2,8,2,0"
                       FontSize="11" Foreground="#FF808080"
                       Text="↑↓ select · Enter paste · Esc close" />
        </Grid>
    </Border>
</Window>
