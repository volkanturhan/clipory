<Window x:Class="ClipStack.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:ClipStack.Services"
        Title="ClipStack"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="White">
    <StackPanel Margin="24">

        <!-- Icon + name + version -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Image Source="pack://application:,,,/Assets/ClipStack.ico"
                   Width="48" Height="48" />
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="ClipStack" FontSize="20" FontWeight="SemiBold"
                           Foreground="#111827" />
                <TextBlock x:Name="VersionText" FontSize="12" Foreground="#6B7280" />
            </StackPanel>
        </StackPanel>

        <TextBlock Text="{Binding [AboutDescription], Source={x:Static services:Localization.Instance}}"
                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,18,0,0"
                   Foreground="#374151" />

        <TextBlock Text="by Volkan Turhan" TextAlignment="Center"
                   Margin="0,14,0,0" Foreground="#6B7280" />

        <TextBlock TextAlignment="Center" Margin="0,4,0,0">
            <Hyperlink NavigateUri="https://github.com/volkanturhan/ClipStack"
                       RequestNavigate="OnNavigate">github.com/volkanturhan/ClipStack</Hyperlink>
        </TextBlock>

        <TextBlock Text="MIT License" TextAlignment="Center" Margin="0,4,0,0"
                   FontSize="12" Foreground="#9CA3AF" />

        <Button Content="{Binding [AboutClose], Source={x:Static services:Localization.Instance}}"
                Click="OnClose" Margin="0,22,0,0" Padding="22,6"
                HorizontalAlignment="Center" IsDefault="True" IsCancel="True" />
    </StackPanel>
</Window>
